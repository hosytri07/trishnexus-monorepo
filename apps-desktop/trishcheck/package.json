{
  "name": "@trishteam/trishcheck",
  "version": "2.0.0-1",
  "private": true,
  "description": "TrishCheck — system info + benchmark tool cho TrishTEAM ecosystem. Giúp user check máy có đủ power chạy ứng dụng nặng (TrishImage face-group, TrishFont render), đồng thời làm smoke test cross-platform khi rebuild.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@trishteam/core": "workspace:*",
    "@tauri-apps/api": "^2.0.0",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "5.4.5",
    "vite": "^5.4.0"
  }
}
