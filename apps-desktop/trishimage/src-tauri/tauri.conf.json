{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TrishImage",
  "version": "2.0.0-alpha.1",
  "identifier": "vn.trishteam.image",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1430",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "TrishImage — Photo organizer",
        "width": 1180,
        "height": 780,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' data: asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "msi",
      "nsis",
      "dmg",
      "deb",
      "appimage"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Photography",
    "copyright": "© 2026 TrishTEAM",
    "shortDescription": "Photo organizer với event/face grouping",
    "longDescription": "TrishImage quét thư mục ảnh, đọc EXIF + dimensions (không decode pixel), nhóm thành event theo time gap, và phân loại aspect ratio + face bucket. Tối ưu cho gallery cá nhân.",
    "publisher": "TrishTEAM"
  }
}
