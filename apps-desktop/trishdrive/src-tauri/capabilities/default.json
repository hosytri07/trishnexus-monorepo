{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "TrishDrive User app — dialog (chọn file/folder save), opener (mở folder + URL trishteam.io.vn), core IPC, tray icon (Phase 26.5.A).",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-set-focus",
    "core:window:allow-unminimize",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "opener:default",
    "opener:allow-open-path",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "https://t.me/*" },
        { "url": "https://core.telegram.org/*" },
        { "url": "https://github.com/*" },
        { "url": "https://trishteam.io.vn/*" }
      ]
    }
  ]
}
