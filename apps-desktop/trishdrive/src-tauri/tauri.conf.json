{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TrishDrive",
  "version": "0.1.0-alpha.1",
  "identifier": "vn.trishteam.drive",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:3001",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "TrishDrive — Cloud Storage qua Telegram",
        "width": 1200,
        "height": 760,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' data: asset: http://asset.localhost https://*.t.me; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; font-src 'self' data:; connect-src 'self' https://api.telegram.org https://*.googleapis.com https://*.firebaseio.com https://trishteam.io.vn"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "copyright": "© 2026 TrishTEAM",
    "shortDescription": "TrishDrive — Cloud Storage qua Telegram",
    "longDescription": "Lưu trữ file không giới hạn dung lượng qua Telegram. Upload chia chunk + AES-256 encrypt + SQLite index. Bot API cho file < 50MB, MTProto cho file lớn hơn (Phase 23).",
    "publisher": "TrishTEAM",
    "homepage": "https://trishteam.io.vn",
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "languages": ["English", "Vietnamese"],
        "displayLanguageSelector": true,
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}
