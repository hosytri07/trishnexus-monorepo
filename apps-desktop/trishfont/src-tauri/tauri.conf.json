{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TrishFont",
  "version": "1.0.0",
  "identifier": "vn.trishteam.font",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1426",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "TrishFont — Quản lý font",
        "width": 1280,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 720,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; img-src 'self' data: asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'; font-src 'self' data: asset: http://asset.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "copyright": "© 2026 TrishTEAM",
    "shortDescription": "Quản lý + cài đặt font tiếng Việt",
    "longDescription": "TrishFont quản lý thư viện font cá nhân: scan folder, preview live (FontFace API), tìm font hỗ trợ tiếng Việt, cài đặt vào Windows một-click không cần admin.",
    "publisher": "TrishTEAM",
    "homepage": "https://trishteam.io.vn",
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": [
          "English",
          "Vietnamese"
        ],
        "displayLanguageSelector": true,
        "installerIcon": "icons/icon.ico"
      },
      "wix": {
        "language": [
          "en-US",
          "vi-VN"
        ]
      }
    },
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "librsvg2-2"
        ],
        "section": "fonts"
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15",
      "dmg": {
        "windowSize": {
          "width": 660,
          "height": 400
        }
      }
    },
    "createUpdaterArtifacts": false
  }
}