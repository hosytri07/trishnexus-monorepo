{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "useDefineForClassFields": true,
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@trishteam/core": ["../../packages/core/src/index.ts"],
      "@trishteam/core/*": ["../../packages/core/src/*"],
      "@trishteam/auth": ["../../packages/auth/src/index.ts"],
      "@trishteam/auth/react": ["../../packages/auth/src/react.tsx"],
      "@trishteam/data": ["../../packages/data/src/index.ts"],
      "@trishteam/data/*": ["../../packages/data/src/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "../../packages/*/src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "src-tauri",
    "../../packages/*/node_modules",
    "../../packages/*/dist",
    "../../packages/*/src/**/__tests__/**",
    "../../packages/*/vitest.config.ts"
  ]
}
