{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "TrishAdmin — capabilities cho admin tool: dialog (pick file registry edit), opener (mở repo URL).",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "opener:default",
    "opener:allow-open-path",
    "opener:allow-open-url"
  ]
}
