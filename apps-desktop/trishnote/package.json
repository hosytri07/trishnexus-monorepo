{
  "name": "@trishteam/trishnote",
  "version": "2.0.0-1",
  "private": true,
  "description": "TrishNote — ghi chú cá nhân + dự án có deadline. Rich text + đính kèm file/link + thùng rác. Tauri 2 + Firebase Auth + per-UID local storage.",
