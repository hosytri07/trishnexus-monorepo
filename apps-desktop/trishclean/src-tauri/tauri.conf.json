{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TrishClean",
  "version": "1.0.0",
  "identifier": "vn.trishteam.clean",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1424",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "TrishClean — Dọn dẹp máy an toàn",
        "width": 1000,
        "height": 680,
        "minWidth": 820,
        "minHeight": 520,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; connect-src 'self' ipc: http://ipc.localhost https://api.github.com https://*.github.com https://trishteam.io.vn; img-src 'self' data: asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "copyright": "© 2026 TrishTEAM",
    "shortDescription": "Dọn dẹp máy với undo 7 ngày",
    "longDescription": "TrishClean quét cache, temp, download cũ và file trùng lặp. Không xoá thật ngay — file chuyển sang trash riêng, giữ 7 ngày trước khi xoá vĩnh viễn.",
    "publisher": "TrishTEAM",
    "homepage": "https://trishteam.io.vn",
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": [
          "English",
          "Vietnamese"
        ],
        "displayLanguageSelector": true,
        "installerIcon": "icons/icon.ico"
      },
      "wix": {
        "language": [
          "en-US",
          "vi-VN"
        ]
      }
    },
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "active": false,
      "endpoints": [
        "https://trishteam.io.vn/api/updates/trishclean/{{target}}/{{current_version}}"
      ],
      "pubkey": "PLACEHOLDER_RUN_TAURI_SIGNER_GENERATE_TO_REPLACE",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
