{
  "name": "@trishteam/trishclean",
  "version": "1.0.0",
  "private": true,
  "description": "TrishClean — dọn dẹp file/cache với undo 7 ngày (staged delete). Tauri 2 + @trishteam/core/clean cho scan logic. Không xoá thật ngay — move sang trash folder riêng, commit sau retention window.",
  "type": "module",
  "scripts": {
