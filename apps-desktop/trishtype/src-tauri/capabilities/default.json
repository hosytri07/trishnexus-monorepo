{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "TrishType cần dialog (open/save .txt/.md) + fs.read/write để load và lưu file văn bản. Không cấp shell/http.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:default",
    "fs:allow-read-file",
    "fs:allow-write-file"
  ]
}
