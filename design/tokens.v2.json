{
  "_meta": {
    "name": "TrishTEAM Design Tokens v2 — 2-theme system (Dark + Light)",
    "version": "2.1.0",
    "description": "2 theme duy nhất: 'dark' (warm charcoal — default) và 'light' (off-white neutral). Chốt (2026-04-23 — Phase 13.5 simplify): bỏ 5 theme chỉ-để-khoe (midnight/aurora/sunset/ocean/forest/candy), giữ UX đơn giản. Rule: text phải tương phản rõ với background (WCAG AA trở lên) — dark mode text sáng trên nền tối ấm; light mode text tối trên nền trắng ngà. Typography/spacing/radius/shadow/motion/zIndex là theme-independent.",
    "lastUpdated": "2026-04-23",
    "roadmapRef": "docs/ROADMAP.md#phase-13--design-language-refresh-v2",
    "compatibility": "Key 'trishwarm' giữ alias tới 'dark' (backward compat — persist file cũ user có thể chứa 'trishwarm'). Key 'candy' alias tới 'light'."
  },

  "default_theme": "dark",

  "themes": {
    "dark": {
      "label": "Tối (Dark)",
      "description": "Warm charcoal — tone nâu đen ấm, mặc định cho user Việt dân engineering. Text off-white ấm (#f5f2ed) trên nền tối (#0f0e0c) — WCAG AAA contrast.",
      "mode": "dark",
      "color": {
        "accent": {
          "primary":   "#667EEA",
          "secondary": "#764BA2",
          "gradient":  "linear-gradient(135deg, #667EEA 0%, #764BA2 100%)",
          "focus":     "#667EEA"
        },
        "surface": {
          "bg":          "#0f0e0c",
          "bg_elevated": "#1a1814",
          "card":        "#1a1814",
          "row":         "#1e1c18",
          "muted":       "rgba(255,255,255,0.05)",
          "hover":       "rgba(102,126,234,0.10)",
          "overlay":     "rgba(0,0,0,0.6)"
        },
        "text": {
          "primary":   "#f5f2ed",
          "secondary": "#d4cec4",
          "muted":     "#a09890",
          "inverse":   "#0f0e0c",
          "link":      "#8FA5FF"
        },
        "border": {
          "subtle":  "rgba(255,255,255,0.06)",
          "default": "rgba(255,255,255,0.08)",
          "strong":  "rgba(255,255,255,0.12)",
          "focus":   "#667EEA"
        }
      }
    },

    "light": {
      "label": "Sáng (Light)",
      "description": "Off-white neutral — nền ngà (#f7f6f3), card trắng tinh (#ffffff), text charcoal đậm (#1a1814). Cùng hue warm với dark mode (inverse) nên logo + accent không bị lạc tone. WCAG AAA contrast cho text chính.",
      "mode": "light",
      "color": {
        "accent": {
          "primary":   "#667EEA",
          "secondary": "#764BA2",
          "gradient":  "linear-gradient(135deg, #667EEA 0%, #764BA2 100%)",
          "focus":     "#667EEA"
        },
        "surface": {
          "bg":          "#f7f6f3",
          "bg_elevated": "#ffffff",
          "card":        "#ffffff",
          "row":         "#faf9f6",
          "muted":       "#eeece7",
          "hover":       "rgba(102,126,234,0.08)",
          "overlay":     "rgba(15,14,12,0.48)"
        },
        "text": {
          "primary":   "#1a1814",
          "secondary": "#3c3833",
          "muted":     "#78746e",
          "inverse":   "#ffffff",
          "link":      "#5163cf"
        },
        "border": {
          "subtle":  "rgba(15,14,12,0.06)",
          "default": "rgba(15,14,12,0.10)",
          "strong":  "rgba(15,14,12,0.18)",
          "focus":   "#667EEA"
        }
      }
    }
  },

  "theme_aliases": {
    "_comment": "Backward compat — persist file cũ có thể chứa 'trishwarm'/'candy'. theme_manager tự map sang 'dark'/'light'.",
    "trishwarm": "dark",
    "midnight":  "dark",
    "aurora":    "dark",
    "sunset":    "dark",
    "ocean":     "dark",
    "forest":    "dark",
    "candy":     "light"
  },

  "semantic": {
    "_comment": "Theme-independent — success/warning/danger/info colors giống nhau mọi theme.",
    "success": "#10B981",
    "warning": "#F59E0B",
    "danger":  "#EF4444",
    "info":    "#3B82F6"
  },

  "group": {
    "_comment": "Group colors dùng cho font category, project type, v.v. Theme-independent.",
    "primary": "#667EEA",
    "green":   "#10B981",
    "amber":   "#F59E0B",
    "cyan":    "#06B6D4",
    "blue":    "#3B82F6"
  },

  "font": {
