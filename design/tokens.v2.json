    "16": "56px",
    "20": "72px"
  },

  "radius": {
    "_comment": "Theme-independent — shape language nhất quán across themes.",
    "none": "0px",
    "sm":   "6px",
    "md":   "8px",
    "lg":   "12px",
    "xl":   "16px",
    "2xl":  "20px",
    "full": "9999px"
  },

  "shadow": {
    "_comment": "Dark-ready shadow — alpha cao vì nền tối cần contrast mạnh. Light theme cũng dùng được vì rgba(0,0,0,...) luôn darken.",
    "xs": "0 1px 2px 0 rgba(0,0,0,0.20)",
    "sm": "0 1px 3px 0 rgba(0,0,0,0.30)",
    "md": "0 4px 8px 0 rgba(0,0,0,0.35)",
    "lg": "0 8px 20px 0 rgba(0,0,0,0.45)",
    "xl": "0 20px 40px 0 rgba(0,0,0,0.55)",
    "2xl":"0 30px 60px 0 rgba(0,0,0,0.65)"
  },

  "motion": {
    "_comment": "Theme-independent — animation timing nhất quán.",
    "duration": {
      "instant": "0ms",
      "fast":    "150ms",
      "normal":  "240ms",
      "slow":    "360ms",
      "slower":  "500ms"
    },
    "easing": {
      "standard":  "cubic-bezier(0.2, 0, 0, 1)",
      "emphasize": "cubic-bezier(0.3, 0, 0, 1)",
      "bounce":    "cubic-bezier(0.68, -0.55, 0.27, 1.55)",
      "linear":    "linear"
    }
  },

  "zIndex": {
    "_comment": "Layer stacking order — áp dụng cho cả web lẫn desktop modal.",
    "base":     0,
    "dropdown": 100,
    "sticky":   200,
    "overlay":  300,
    "modal":    400,
    "toast":    500,
    "tooltip":  600
  },

  "icons": {
    "_comment": "Icon library convention — xem Phase 13.2 task #68. Desktop dùng SVG từ shared/trishteam_core/icons/lucide/, Web dùng npm package lucide-react.",
    "library": "lucide",
    "source":  "https://lucide.dev",
    "subset_location": "shared/trishteam_core/icons/lucide/",
    "web_package":     "lucide-react",
    "default_size":    "18px",
    "default_stroke":  1.75
  }
}
