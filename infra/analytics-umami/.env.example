# Umami .env — copy sang .env rồi điền giá trị thật.
# KHÔNG commit .env (đã trong .gitignore).

# Postgres password — ít nhất 24 ký tự random:
#   openssl rand -base64 32
POSTGRES_PASSWORD=CHANGE_ME_LONG_RANDOM_STRING

# Umami APP_SECRET — token để sign session cookies. Random 32 bytes:
#   openssl rand -hex 32
APP_SECRET=CHANGE_ME_32_BYTES_HEX
