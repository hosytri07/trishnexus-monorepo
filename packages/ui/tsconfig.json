{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM"],
    "outDir": "./dist",
    "rootDir": "./src",
    "types": ["react", "react-dom"],
    "paths": {
      "@trishteam/core": ["../core/src/index.ts"],
      "@trishteam/core/*": ["../core/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["dist", "node_modules"]
}
