{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@trishteam/core": ["../packages/core/src/index.ts"],
      "@trishteam/core/*": ["../packages/core/src/*"],
      "@trishteam/ui": ["../packages/ui/src/index.ts"],
      "@trishteam/ui/*": ["../packages/ui/src/*"],
      "@trishteam/data": ["../packages/data/src/index.ts"],
      "@trishteam/data/*": ["../packages/data/src/*"],
      "@trishteam/adapters": ["../packages/adapters/src/index.ts"],
      "@trishteam/adapters/*": ["../packages/adapters/src/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "../packages/*/src/**/*.ts",
    "../packages/*/src/**/*.tsx"
  ],
  "exclude": [
    "node_modules",
    "../packages/*/node_modules",
    "../packages/*/dist",
    "../packages/*/src/**/__tests__/**",
    "../packages/*/vitest.config.ts"
  ]
}
