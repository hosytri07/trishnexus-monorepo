# TrishTEAM website — biến môi trường mẫu
# Copy thành .env.local (đã ignore trong .gitignore) và điền giá trị thật.
#
# Cách lấy Firebase config: Firebase Console → Project settings → General →
# "Your apps" → chọn Web app → copy từng trường từ snippet firebaseConfig.
#
# Phase 16.1.f — Mock mode đã bị remove. Bắt buộc phải có Firebase config
# (nếu thiếu, app sẽ render guest mode — không login được).

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Server-side (dùng bởi scripts/seed-admin.ts, scripts/reset-release.ts,
# và API route /api/admin/set-role ở Phase 11.8.5).
# Download từ Firebase Console → Project settings → Service accounts →
# "Generate new private key" → lưu vào ./secrets/service-account.json
# và đặt biến này trỏ đến file đó. KHÔNG commit file JSON.
GOOGLE_APPLICATION_CREDENTIALS=./secrets/service-account.json

# Production (Vercel/Firebase Hosting) — paste nội dung JSON service account
# hoặc base64 của nó vào đây. API route /api/admin/set-role ưu tiên biến này.
# FIREBASE_SERVICE_ACCOUNT='{"type":"service_account",...}'

# Phase 12.3 — Semantic search (Gemini text-embedding-004).
# Lấy key ở https://aistudio.google.com/app/apikey (miễn phí 1500 req/day).
# Không set cũng OK — /api/embed sẽ fallback local hash 256-dim (dev only).
# GOOGLE_AI_API_KEY=

# Phase 16.2 — Site URL dùng cho metadataBase + sitemap + robots.
# Production: https://trishteam.io.vn · Preview: URL Vercel preview tự gen.
# NEXT_PUBLIC_SITE_URL=https://trishteam.io.vn

# Phase 17.1 — App version (bump mỗi release để tag source map + filter
# error theo version trong /admin/errors).
# NEXT_PUBLIC_APP_VERSION=1.0.0

# Phase 16.6 — Umami privacy-first analytics (self-host).
# Nếu chưa dựng Umami, để trống — UmamiTracker render null, không request.
# Xem docs/ANALYTICS-UMAMI.md.
# NEXT_PUBLIC_UMAMI_SRC=https://analytics.trishteam.io.vn/script.js
# NEXT_PUBLIC_UMAMI_WEBSITE_ID=
# NEXT_PUBLIC_UMAMI_DOMAINS=trishteam.io.vn

# Phase 19.12 — Cloudinary (storage ảnh primary)
# Đăng ký free tại https://cloudinary.com/users/register/free (25GB + 25GB/month)
# Sau khi đăng ký: Dashboard → Account Details → copy 3 trường dưới
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
