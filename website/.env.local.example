# Copy file này sang `.env.local` và điền credentials thật của bạn.
# `.env.local` đã được gitignore — token sẽ không bị commit.

# Telegram bot nhận góp ý người dùng.
# Tạo bot mới: mở https://t.me/BotFather → /newbot → lấy HTTP API token.
# Chat ID lấy từ @userinfobot (cá nhân) hoặc @RawDataBot (group).
TELEGRAM_BOT_TOKEN=your_telegram_bot_http_api_token_here
TELEGRAM_CHAT_ID=your_numeric_chat_id_here
