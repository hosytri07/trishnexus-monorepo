rules_version = '2';

// TrishTEAM Firestore Security Rules — Phase 16.1.c
//
// 4 roles:
//   - admin    — toàn quyền hệ sinh thái (manual set qua Firebase Console)
//   - user     — đã kích hoạt key, dùng đầy đủ tính năng + sync data riêng
//   - trial    — chưa kích hoạt key, default khi đăng ký, chỉ xem demo
//   - guest    — chưa login, không có doc trong /users/
//
// Sau khi deploy:
//   firebase deploy --only firestore:rules

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helpers ---
    function signedIn() {
      return request.auth != null;
    }
    function isSelf(uid) {
      return signedIn() && request.auth.uid == uid;
    }
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    function userExists() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    function isAdmin() {
      return signedIn() && (
        request.auth.token.admin == true ||
        (userExists() && userDoc().data.role == 'admin')
      );
    }
    function isPaidUser() {
      // role == 'user' (đã kích hoạt key) HOẶC admin
      return signedIn() && (
        isAdmin() ||
        (userExists() && userDoc().data.role == 'user')
      );
    }
    function isAnyMember() {
      // Bất kỳ user đã đăng ký (admin/user/trial)
      return signedIn() && userExists();
    }

    // --- /users/{uid} ---
    // Owner: CRUD doc của mình. Bình thường KHÔNG tự đổi role được.
    // EXCEPTION: activate key flow Trial → User trong cùng transaction với
    // /keys/{kid}.status = 'used' (đảm bảo key consumed atomic).
    // Admin: đọc all + đổi role tuỳ ý.
    match /users/{uid} {
      allow read: if isSelf(uid) || isAdmin();
      allow create: if isSelf(uid)
        && request.resource.data.role in ['trial', 'user']
        && (request.resource.data.role == 'trial' || isAdmin());

      // Update có 3 case hợp lệ:
      //   1. Self update field thường (không đổi role)
      //   2. Self activate key: trial → user + key_activated_at > 0 + activated_key_id set
      //   3. Admin update bất kỳ
      allow update: if isAdmin()
        || (isSelf(uid) && request.resource.data.role == resource.data.role)
        || (
          isSelf(uid)
          && resource.data.role == 'trial'
          && request.resource.data.role == 'user'
          && request.resource.data.key_activated_at > 0
          && request.resource.data.activated_key_id is string
          && request.resource.data.activated_key_id.size() > 0
        );
      allow delete: if isAdmin();

      // Activity events (append-only, owner + admin read).
      match /events/{eventId} {
        allow read: if isSelf(uid) || isAdmin();
        allow create: if isSelf(uid)
          && request.resource.data.kind is string
          && request.resource.data.title is string;
        allow update, delete: if false;
      }

      // Per-app progress.
      match /progress/{appId} {
        allow read, write: if isSelf(uid);
      }

      // Phase 16.2 — TrishLibrary per-user data sync
      // Files (scan folder local) + online folders (links + QR) + trishteam_folders cache
      // Chỉ owner đọc/ghi. Admin KHÔNG được đọc — privacy guarantee.
      match /trishlibrary/{docId} {
        allow read, write: if isSelf(uid) && isPaidUser();
      }
      match /trishlibrary/{docId}/items/{itemId} {
        allow read, write: if isSelf(uid) && isPaidUser();
      }
    }

    // --- /announcements/{id} ---
    // Phase 19.22 — public read cho banner trên homepage hiện cả khi guest.
    match /announcements/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // --- /notes/{uid}/items/{noteId} ---
    match /notes/{uid}/items/{noteId} {
      allow read, write: if isSelf(uid);
    }

    // --- Phase 19.14 — /documents/{uid}/items/{docId} (Tài liệu) ---
    match /documents/{uid}/items/{docId} {
      allow read, write: if isSelf(uid);
    }

    // --- Phase 19.14 — /photos/{uid}/items/{photoId} (Ảnh — Cloudinary refs) ---
    match /photos/{uid}/items/{photoId} {
      allow read, write: if isSelf(uid);
    }

    // --- /feedback/{id} ---
    match /feedback/{id} {
      allow create: if signedIn() && request.resource.data.uid == request.auth.uid;
      allow read: if isAdmin()
        || (signedIn() && resource.data.uid == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    // --- /audit/{id} ---
    // Phase 18.8.a — Admin write audit từ TrishAdmin app khi thực hiện
    // action quan trọng (sinh key, đổi role, revoke, ...). Append-only.
    match /audit/{id} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    // --- /posts/{id} ---
    match /posts/{id} {
      allow read: if resource.data.status == 'published' || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // --- Phase 16.1.c + Phase 36.1 — /keys/{keyId} (activation keys) ---
    // Phase 16.1.c schema: { code, status, created_at, used_by_uid?, used_at?, note? }
    // Phase 36.1 schema: + type ('account'|'standalone'), app_id, bound_uid, bound_machine_id,
    //                      max_concurrent, recipient, expires_at, activated_at
    //
    // Admin tạo + revoke + delete + extend. User read keys active (để query activate).
    // User update khi activate atomic flow (status active → used + bound_uid = self).
    match /keys/{keyId} {
      allow read: if isAdmin()
        || (signedIn() && resource.data.status == 'active')
        // Phase 36.1: user đã bound key này được đọc (để app fetch expires_at + max_concurrent)
        || (signedIn() && resource.data.bound_uid == request.auth.uid);
      allow create: if isAdmin();
      allow update: if isAdmin()
        // Phase 16.1.c legacy activation (không có type/app_id)
        || (signedIn()
            && resource.data.status == 'active'
            && request.resource.data.status == 'used'
            && request.resource.data.used_by_uid == request.auth.uid)
        // Phase 36.1 — Account key activation: user nhập key cho 1 app cụ thể
        || (signedIn()
            && resource.data.status == 'active'
            && request.resource.data.status == 'used'
            && request.resource.data.bound_uid == request.auth.uid
            && resource.data.type == 'account');
      allow delete: if isAdmin();

      // Phase 36.1 — Active sessions subcollection
      // Track concurrent control. Owner (bound_uid) + admin đọc; ghi chỉ Cloud Function.
      match /sessions/{sessionId} {
        allow read: if isAdmin()
          || (signedIn() && get(/databases/$(database)/documents/keys/$(keyId)).data.bound_uid == request.auth.uid);
        // Phase 24.3 — Allow admin trực tiếp xóa session (force kick)
        // và ghi (heartbeat update) khi user đã bound.
        allow delete: if isAdmin();
        allow write: if false; // Cloud Function only (Admin SDK bypass)
      }
    }

    // --- Phase 24.3 — collectionGroup('sessions') query ---
    // Required cho ActiveSessionsPanel listActiveSessions() — query mọi sessions
    // qua collectionGroup. Rule trên path-specific (/keys/{keyId}/sessions) KHÔNG
    // cover collectionGroup; phải có rule riêng dùng path wildcard.
    match /{path=**}/sessions/{sessionId} {
      allow read: if isAdmin();
    }

    // --- Phase 24.3 — /session_history/{id} ---
    // Audit trail các session đã kết thúc (kick/expire/logout/replaced).
    // Admin đọc all + write (khi force kick + sweep). Append-only.
    match /session_history/{id} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if isAdmin(); // admin có thể purge cũ
    }

    // --- Phase 38.8 — /promo_codes/{code} (readable promo codes) ---
    // Doc ID = code chữ hoa (vd "TRIAL2026"). Admin tạo/sửa/disable.
    // User KHÔNG đọc/ghi trực tiếp — activate qua POST /api/promo/activate (Admin SDK bypass).
    match /promo_codes/{code} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // --- Phase 24.3 — /alerts/{id} (security alerts) ---
    // Suspicious activity detector tạo alert (multi-IP, blacklist, proxy).
    // Admin đọc + ack/delete. Detector chạy trong TrishAdmin nên client write.
    match /alerts/{id} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // --- Phase 24.3 — /ip_geo/{ip} (IP → country/city/ISP/proxy cache) ---
    // Cache result của ip-api.com để giảm rate-limit. Admin write-back khi miss.
    // Public read (cũng có thể dùng client-side ở app khác).
    match /ip_geo/{ip} {
      allow read: if signedIn();
      allow create, update: if isAdmin();
      allow delete: if isAdmin();
    }

    // --- Phase 36.1 — /device_activations/{compositeId} ---
    // Composite ID = "{machine_id}_{app_id}" cho apps no-login (Shortcut/Check/Clean/Font).
    // Read: signed user nào cũng được query theo doc ID (vì cần check máy mình đã activate chưa).
    // Write: chỉ Cloud Function (atomic với key.status update).
    match /device_activations/{compositeId} {
      allow read: if signedIn() || isAdmin();
      allow write: if false;
    }

    // --- Phase 36.1 — /audit_logs/{logId} ---
    // Append-only log mọi action liên quan key/session/permission.
    // Admin đọc full; user đọc log của chính mình (uid match).
    // Write: chỉ Cloud Function (Admin SDK).
    match /audit_logs/{logId} {
      allow read: if isAdmin()
        || (signedIn() && resource.data.uid == request.auth.uid);
      allow write: if false;
    }

    // --- Phase 15.2/16.2 — /trishteam_library/{folderId} (admin curated) ---
    // Top-level collection (path 1 segment để Firestore valid odd-segments).
    // Phase 20.2 — đổi public read để Zalo Mini App MVP (chưa có Firebase Auth)
    // có thể đọc tài nguyên admin curated. Triết lý: thư viện là chia sẻ cộng đồng.
    // Admin tạo/sửa/xóa folders + links.
    match /trishteam_library/{folderId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /trishteam_library/{folderId}/links/{linkId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // --- Phase 19.13 — /sign_images/{code} (admin upload Cloudinary publicId) ---
    // Public read (page /bien-bao công khai). Admin CRUD.
    match /sign_images/{code} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // --- Phase 19.13 — /bridge_images/{id} (admin upload Cloudinary publicId) ---
    match /bridge_images/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // --- /{path=**}/events/{eventId} (admin cross-user) ---
    match /{path=**}/events/{eventId} {
      allow read: if isAdmin();
    }

    // --- /semantic/{kind}/items/{docId} ---
    match /semantic/{kind}/items/{docId} {
      allow read: if signedIn() && (kind == 'apps' || kind == 'announcements' || isAdmin()
        || (kind == 'notes' && docId.matches(request.auth.uid + '_.*')));
      allow create, update: if isAdmin()
        || (kind == 'notes' && docId.matches(request.auth.uid + '_.*')
            && request.resource.data.vec is list
            && request.resource.data.model is string);
      allow delete: if isAdmin()
        || (kind == 'notes' && docId.matches(request.auth.uid + '_.*'));
    }

    // --- /vitals/{env}/samples/{id} ---
    match /vitals/{env}/samples/{sampleId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // --- /errors/{env}/samples/{id} ---
    match /errors/{env}/samples/{sampleId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // --- Phase 19.22 — /_meta/{key} (counter, app config) ---
    // Public read (cho UI hiển thị stats). Write chỉ admin (qua API hoặc client transaction).
    match /_meta/{key} {
      allow read: if true;
      allow create, update: if isAdmin();
      allow delete: if false;
    }

    // --- Phase 19.22 — /apps_meta/{appId} (admin sửa app metadata) ---
    // Public read (cho /downloads, /dl, popup app trên dashboard)
    // Admin write (qua /admin/apps)
    match /apps_meta/{appId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // --- Phase 41 — /apps_catalog/{appId} (TrishAdmin Firestore-backed app catalog) ---
    // Source of truth mới cho TrishLauncher app list (replace static apps-registry.json).
    // Khác với /apps_meta (dùng cho website /downloads) — /apps_catalog là dataset
    // riêng cho Launcher fetch, cho phép admin add app NGOÀI hệ sinh thái
    // (Photoshop, AutoCAD, OBS, VLC, etc.) với logo + link tải.
    //
    // Public read (Launcher fetch không cần signed-in để render catalog).
    // Admin write only.
    match /apps_catalog/{appId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // --- Phase 42 — /gis_markers/{markerId} (GIS markers TrishDesign) ---
    // Admin cung cấp danh mục tọa độ: mốc đường chuyền các cấp, mốc giả định,
    // biển báo, cọc H... theo Tỉnh / QL / Lý trình.
    // Public read (TrishDesign user fetch). Admin write.
    match /gis_markers/{markerId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // --- Phase 42 wave 8.3 — /atgt_blocks/{blockId} (ATGT block catalog) ---
    // Admin curate danh mục block .dwg cho TrishDesign Vẽ hiện trạng ATGT.
    // Public read (TrishDesign user fetch dropdown). Admin write.
    match /atgt_blocks/{blockId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // --- Phase 43 wave 10.5 — /system_config/{doc} (config khoá-giá trị toàn hệ thống) ---
    match /system_config/{doc} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // --- Phase 43 wave 15.2 — /atgt_files/{fileNameId} (per-file metadata) ---
    // Admin upload từng file .dwg → 1 doc. TrishDesign user fetch list để incremental sync.
    match /atgt_files/{fileId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // --- Phase 19.22 — Database collections (admin CRUD, public read) ---
    // standards (QCVN/TCVN/Thông tư...) · dinh_muc (định mức) · vat_lieu · roads_vn
    match /standards/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /dinh_muc/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /vat_lieu/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }
    match /roads_vn/{id} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // --- Phase 19.22 — /short_links/{code} (URL shortener TrishTEAM) ---
    // Public read (cho /s/[code] redirect). Write chỉ qua Admin SDK
    // (server-side /api/shorten + /api/admin/*) — bypass rules.
    match /short_links/{code} {
      allow read: if true;
      allow write: if false;
    }

    // --- Phase 22.7b — /trishdrive/{...} (TrishDrive shares + future user data) ---
    // KHÔNG cho client truy cập trực tiếp (chứa encrypted bot_token + master_key).
    // Mọi truy cập đi qua /api/drive/* (Admin SDK bypass rules).
    match /trishdrive/{doc=**} {
      allow read, write: if false;
    }

    // --- Phase 28.8 — /admin_settings/{tenantId}/... (encrypted API keys + audit) ---
    // Schema:
    //   /admin_settings/{tenant}/api_keys/{provider}
    //     { encrypted, updatedAt, modifiedBy, modifiedByEmail, version }
    //   /admin_settings/{tenant}/audit_log/{autoId}
    //     { provider, action, modifiedBy, modifiedByEmail, timestamp, note? }
    //
    // Permission:
    //   - Admin: full CRUD (set/delete keys + write audit).
    //   - Paid user: READ api_keys (TrishDesign auto-fetch + decrypt local).
    //     Vì cipher đã AES-GCM encrypted nên paid user "có thể đọc" nhưng
    //     master key hardcoded trong source desktop app — đây là layer
    //     defense-in-depth, không phải bảo vệ tuyệt đối.
    //   - Audit log: chỉ admin đọc, append-only, không update/delete.
    //   - Trial / guest: deny tất cả.
    match /admin_settings/{tenantId}/api_keys/{provider} {
      allow read: if isPaidUser();
      allow create, update, delete: if isAdmin();
    }
    match /admin_settings/{tenantId}/audit_log/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
      allow update, delete: if false;
    }

    // --- Phase 28.14 — /lisp_library/{id} (TrishTEAM curated AutoLISP) ---
    // Admin upload + manage. Paid user read + download (file lưu Telegram).
    match /lisp_library/{lispId} {
      allow read: if isPaidUser();
      allow create, update, delete: if isAdmin();
    }

    // --- Phase 38.18 — /trishoffice_companies/{ownerUid}/... (TrishOffice cloud sync) ---
    // Mỗi công ty có 1 root doc /trishoffice_companies/{ownerUid}/.
    // ownerUid = Firebase uid của admin cty đó. Tất cả collections business
    // (employees, attendance, assets, workflows, documents, payroll, contracts,
    // expenses, departments) lưu dưới đó.
    //
    // Owner cty: full CRUD cho data của mình.
    // Admin TrishTEAM (Trí): full access cross-cty (debug + support).
    // User khác: deny.
    match /trishoffice_companies/{ownerUid}/{collection}/{docId} {
      allow read, write: if signedIn() && (request.auth.uid == ownerUid || isAdmin());
    }

    // --- Default deny ---
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
